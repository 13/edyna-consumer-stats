# Required
LOGIN_URL=https://portaledistributore.edyna.net/EIPPUF/EIPPUF/de-AT/dD4/Page/Login.tws?ReturnUrl=%2fEIPPUF%2fEIPPUF%2fde-AT%2fdD4%2fPage%2fSingle.tws
USERNAME=
PASSWORD=

# Browser
HEADLESS=true
DEBUG_SHOTS=false

# Database (required for --db mode)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edyna
DB_USER=
DB_PASSWORD=
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false  # Only disable in development

# Scheduler
CRON_SCHEDULE=0 9 * * *
TZ=Europe/Rome
RUN_ON_START=false

# Retry (scraper retries full browser session on failure)
SCRAPE_RETRIES=1
SCRAPE_RETRY_DELAY_MS=10000

# Logging: debug | info | warn | error
LOG_LEVEL=info
